#!/usr/bin/env bash
# Sweep clxtest_* objects from the live Cortex tenant.
#
# Invoked by `just test` before AND after the BATS run, so a crashed
# write-endpoint test cannot leave permanent fixtures behind. Also
# available standalone via `just test-clean`.
#
# Each reap_* function below:
#   1. Lists tenant objects via the corresponding GET/list endpoint.
#   2. Filters names starting with "clxtest_".
#   3. POSTs the matching deletes.
#   4. Echoes "<n> <noun> removed" if n > 0; stays silent on n == 0.
#
# When a new write endpoint lands in the SDK, add a new reap_<noun>
# function here and append it to $REAPERS. See tests/SETUP_TEARDOWN.md
# for the contract.

set -euo pipefail

cd "$(dirname "$0")/../.."

CURL="./cli/bin/cortex-curl"

: "${CORTEX_TENANT_URL:?set in .envrc}"
: "${CORTEX_API_KEY:?set in .envrc}"
: "${CORTEX_API_KEY_ID:?set in .envrc}"

# --- Reapers -----------------------------------------------------------------
#
# Add new entries here. Each function should be idempotent and silent
# when the tenant has no clxtest_* objects of its kind.
#
# Template:
#
#   reap_<noun>() {
#       local list deletes=0
#       list="$("$CURL" POST /public_api/v1/<list-path> '{"request_data":{}}')"
#       while IFS= read -r name; do
#           [[ -z "$name" ]] && continue
#           "$CURL" POST /public_api/v1/<delete-path> \
#               "$(jq -n --arg n "$name" '{request_data:{name:$n}}')" \
#               >/dev/null
#           deletes=$((deletes + 1))
#       done < <(printf '%s' "$list" | jq -r '.reply[]?.name | select(startswith("clxtest_"))')
#       if (( deletes > 0 )); then echo "$deletes <noun>s removed"; fi
#   }
#
# Note: `(( expr )) && echo …` looks tempting but exits the script under
# `set -e` whenever `expr` is false. Use an explicit `if` block instead.
#
# Then: REAPERS+=(reap_<noun>)

reap_biocs() {
    local list deletes=0
    list="$("$CURL" POST /public_api/v1/bioc/get '{"request_data":{}}')"
    while IFS= read -r name; do
        [[ -z "$name" ]] && continue
        "$CURL" POST /public_api/v1/bioc/delete \
            "$(jq -c -n --arg n "$name" \
                '{request_data:{filters:[{field:"name",operator:"EQ",value:$n}]}}')" \
            >/dev/null
        deletes=$((deletes + 1))
    done < <(printf '%s' "$list" | jq -r '.objects[]? | (.name // "") | select(startswith("clxtest_"))')
    if (( deletes > 0 )); then
        echo "$deletes BIOC(s) removed"
    fi
}

reap_indicators() {
    local list deletes=0
    list="$("$CURL" POST /public_api/v1/indicators/get '{"request_data":{}}')"
    while IFS= read -r name; do
        [[ -z "$name" ]] && continue
        "$CURL" POST /public_api/v1/indicators/delete \
            "$(jq -c -n --arg n "$name" \
                '{request_data:{filters:[{field:"indicator",operator:"EQ",value:$n}]}}')" \
            >/dev/null
        deletes=$((deletes + 1))
    done < <(printf '%s' "$list" | jq -r '.objects[]? | (.indicator // "") | select(startswith("clxtest_"))')
    if (( deletes > 0 )); then
        echo "$deletes IOC(s) removed"
    fi
}

reap_correlations() {
    local list deletes=0
    list="$("$CURL" POST /public_api/v1/correlations/get '{"request_data":{}}')"
    while IFS= read -r name; do
        [[ -z "$name" ]] && continue
        "$CURL" POST /public_api/v1/correlations/delete \
            "$(jq -c -n --arg n "$name" \
                '{request_data:{filters:[{field:"name",operator:"EQ",value:$n}]}}')" \
            >/dev/null
        deletes=$((deletes + 1))
    done < <(printf '%s' "$list" | jq -r '.objects[]? | (.name // "") | select(startswith("clxtest_"))')
    if (( deletes > 0 )); then
        echo "$deletes correlation rule(s) removed"
    fi
}

reap_xql_library() {
    local list names
    list="$("$CURL" POST /public_api/xql_library/get '{"request_data":{}}')"
    names="$(printf '%s' "$list" | jq -c '[.reply.xql_queries[]?.xql_query_name | select(startswith("clxtest_"))]')"
    if [[ "$(printf '%s' "$names" | jq 'length')" -eq 0 ]]; then
        return 0
    fi
    "$CURL" POST /public_api/xql_library/delete \
        "$(jq -c -n --argjson ns "$names" '{request_data:{xql_query_names:$ns}}')" \
        >/dev/null
    echo "$(printf '%s' "$names" | jq 'length') XQL library query/queries removed"
}

reap_scheduled_queries() {
    local list ids
    list="$("$CURL" POST /public_api/v1/scheduled_queries/list '{"request_data":{}}')"
    ids="$(printf '%s' "$list" | jq -c '[.reply.DATA[]? | select(.query_definition_name | startswith("clxtest_")) | .query_def_id]')"
    if [[ "$(printf '%s' "$ids" | jq 'length')" -eq 0 ]]; then
        return 0
    fi
    "$CURL" POST /public_api/v1/scheduled_queries/delete \
        "$(jq -c -n --argjson xs "$ids" '{request_data:$xs}')" \
        >/dev/null
    echo "$(printf '%s' "$ids" | jq 'length') scheduled query/queries removed"
}

REAPERS=(reap_biocs reap_indicators reap_correlations reap_xql_library reap_scheduled_queries)

# --- Driver ------------------------------------------------------------------

for r in "${REAPERS[@]}"; do
    "$r"
done
