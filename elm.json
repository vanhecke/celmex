{
    "type": "package",
    "name": "vanhecke/celmex",
    "summary": "Elm SDK for the Cortex Platform REST API",
    "license": "MIT",
    "version": "3.0.0",
    "exposed-modules": [
        "Cortex.Auth",
        "Cortex.Client",
        "Cortex.Decode",
        "Cortex.Error",
        "Cortex.Query",
        "Cortex.Request",
        "Cortex.RequestData",
        "Cortex.Api.AgentConfig",
        "Cortex.Api.ApiKeys",
        "Cortex.Api.AssetGroups",
        "Cortex.Api.Assets",
        "Cortex.Api.AttackSurface",
        "Cortex.Api.AuditLogs",
        "Cortex.Api.AuthSettings",
        "Cortex.Api.Biocs",
        "Cortex.Api.Cases",
        "Cortex.Api.Cli",
        "Cortex.Api.Correlations",
        "Cortex.Api.DeviceControl",
        "Cortex.Api.DisablePrevention",
        "Cortex.Api.Distributions",
        "Cortex.Api.Endpoints",
        "Cortex.Api.Entries",
        "Cortex.Api.Healthcheck",
        "Cortex.Api.Indicators",
        "Cortex.Api.Issues",
        "Cortex.Api.LegacyExceptions",
        "Cortex.Api.Profiles",
        "Cortex.Api.Quarantine",
        "Cortex.Api.Rbac",
        "Cortex.Api.Risk",
        "Cortex.Api.ScheduledQueries",
        "Cortex.Api.TenantInfo",
        "Cortex.Api.TriagePresets",
        "Cortex.Api.Xql"
    ],
    "elm-version": "0.19.0 <= v < 0.20.0",
    "dependencies": {
        "elm/core": "1.0.0 <= v < 2.0.0",
        "elm/http": "2.0.0 <= v < 3.0.0",
        "elm/json": "1.0.0 <= v < 2.0.0",
        "elm/random": "1.0.0 <= v < 2.0.0",
        "elm/time": "1.0.0 <= v < 2.0.0",
        "elm/url": "1.0.0 <= v < 2.0.0",
        "folkertdev/elm-sha2": "1.0.0 <= v < 2.0.0"
    },
    "test-dependencies": {}
}
