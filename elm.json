{
    "type": "package",
    "name": "jorisv/elm-cortex",
    "summary": "Elm SDK for the Cortex Platform REST API",
    "license": "MIT",
    "version": "1.0.0",
    "exposed-modules": [
        "Cortex.Auth",
        "Cortex.Client",
        "Cortex.Error",
        "Cortex.Request",
        "Cortex.Api.AuditLogs",
        "Cortex.Api.Endpoints",
        "Cortex.Api.Healthcheck",
        "Cortex.Api.TenantInfo"
    ],
    "elm-version": "0.19.0 <= v < 0.20.0",
    "dependencies": {
        "elm/core": "1.0.0 <= v < 2.0.0",
        "elm/http": "2.0.0 <= v < 3.0.0",
        "elm/json": "1.0.0 <= v < 2.0.0",
        "elm/time": "1.0.0 <= v < 2.0.0",
        "elm/random": "1.0.0 <= v < 2.0.0",
        "elm/url": "1.0.0 <= v < 2.0.0",
        "elm/bytes": "1.0.0 <= v < 2.0.0",
        "folkertdev/elm-sha2": "1.0.0 <= v < 2.0.0",
        "rtfeldman/elm-hex": "1.0.0 <= v < 2.0.0",
        "danfishgold/base64-bytes": "1.0.0 <= v < 2.0.0"
    },
    "test-dependencies": {}
}
